{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2022",
    "lib": ["es2023", "dom", "dom.iterable"],
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["**/__tests__/**"]
}
